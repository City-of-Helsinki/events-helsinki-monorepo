{
  "name": "venue-graphql-proxy",
  "version": "1.6.6",
  "private": true,
  "type": "module",
  "description": "Venue GraphQL proxy.",
  "scripts": {
    "build": "cross-env NODE_ENV=production webpack --progress --mode production --config config/webpack.config.mjs",
    "check-dist": "",
    "clean": "rimraf --no-glob ./tsconfig.tsbuildinfo",
    "dev": "cross-env DOTENV_CONFIG_PATH=./.env nodemon ./src/index.ts",
    "docker:build": "cross-env DOCKER_BUILDKIT=1 docker compose -f docker-compose.yml build --progress=tty runner",
    "docker:develop": "cross-env DOCKER_BUILDKIT=1 docker compose -f ./docker-compose.yml up",
    "docker:develop:reinstall": "cross-env DOCKER_BUILDKIT=1 docker compose -f docker-compose.yml build --progress=tty --no-cache --force-rm develop",
    "docker:install": "docker buildx bake -f docker-compose.proxy.yml --progress=tty deps",
    "docker:prune-cache": "docker buildx prune",
    "docker:serve": "docker compose -f docker-compose.yml --env-file .env up runner",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx,.cjs,.mjs,.mdx,.graphql --cache --cache-location ../../.cache/eslint/venue-graphql-proxy.eslintcache",
    "lint-fix": "eslint . --ext .ts,.tsx,.js,.jsx,.cjs,.mjs,.mdx,.graphql --fix",
    "pre-commit": "lint-fix",
    "start": "node -r dotenv-expand/config build",
    "test": "cross-env TZ=Europe/Helsinki vitest run",
    "test:changed": "pnpm run test --changed",
    "test:coverage": "pnpm run test --coverage",
    "test:debug": "cross-env TZ=Europe/Helsinki vitest run --inspect-brk --no-file-parallelism",
    "test:staged": "cross-env TZ=Europe/Helsinki vitest related --run",
    "test:watch": "cross-env TZ=Europe/Helsinki vitest watch",
    "typecheck": "tsc --project ./tsconfig.json --noEmit",
    "generate:graphql": "graphql-codegen"
  },
  "dependencies": {
    "@apollo/datasource-rest": "6.4.1",
    "@apollo/server": "^5.5.0",
    "@apollo/subgraph": "2.13.3",
    "@events-helsinki/graphql-proxy-server": "workspace:^",
    "chalk": "5.4.1",
    "date-fns": "^4.1.0",
    "graphql": "^16.11.0",
    "graphql-tag": "2.12.6",
    "lodash": "4.18.1"
  },
  "devDependencies": {
    "@events-helsinki/eslint-config-bases": "workspace:^",
    "@graphql-codegen/cli": "5.0.7",
    "@graphql-codegen/typescript": "4.1.6",
    "@graphql-codegen/typescript-operations": "4.6.1",
    "@types/lodash": "^4.17.20",
    "@types/node": "24.13.2",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.2",
    "@vitest/eslint-plugin": "1.6.13",
    "@vitest/ui": "4.1.2",
    "cross-env": "7.0.3",
    "dotenv": "^17.2.0",
    "dotenv-expand": "12.0.2",
    "eslint": "9.39.4",
    "husky": "^9.1.7",
    "nodemon": "3.1.10",
    "prettier": "^3.6.2",
    "ts-loader": "9.5.2",
    "ts-node": "10.9.2",
    "tsconfig-paths-webpack-plugin": "4.2.0",
    "tsx": "4.20.3",
    "typescript": "5.8.3",
    "vite": "8.0.6",
    "vitest": "4.1.2",
    "vitest-sonar-reporter": "2.0.4",
    "webpack": "5.104.1",
    "webpack-cli": "6.0.1",
    "webpack-node-externals": "3.0.0"
  }
}
